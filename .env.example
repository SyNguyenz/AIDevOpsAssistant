# ===========================
# AI DevOps Assistant — Config
# Copy file này thành .env và điền giá trị thật
# ===========================

# --- GitHub ---
# Dùng PAT cho dev/test (tạo tại: Settings → Developer settings → Personal access tokens)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Dùng GitHub App cho production
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY_PATH=private-key.pem
# GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# --- LLM Providers ---
# Điền ít nhất 1 key. Router sẽ tự skip provider nào thiếu key.
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false
