# Copy to .env and fill in values. Never commit .env.

# Google AI Studio (primary LLM)
GEMINI_API_KEY=

# Groq (fallback 1)
GROQ_API_KEY=

# OpenAI (fallback 2, optional)
OPENAI_API_KEY=

# GitHub
GITHUB_USER_TOKEN=         # Fine-grained PAT, repo scope
GITHUB_WEBHOOK_SECRET=     # Optional, for webhook signature verification

# PR-Agent config path (point to our overrides)
PR_AGENT_CONFIG_PATH=config/configuration.toml
PR_AGENT_SECRETS_PATH=config/.secrets.toml
